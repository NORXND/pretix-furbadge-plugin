#: .\pretix_furbadge\apps.py:31
msgid "Furry Badges!"
msgstr "Furry Badges!"

#: .\pretix_furbadge\apps.py:34
msgid ""
"Badge templates for pretix with configurable avatar layouts, circular avatar "
"rendering, and Telegram integration support."
msgstr ""
"Szablony badge'y dla pretix z konfigurowalnym układem awatara, renderowaniem "
"okrągłych awatarów oraz wsparciem integracji z Telegramem."

#: .\pretix_furbadge\badge_renderer.py:97
msgid "Background PDF is required"
msgstr "Wymagany jest plik PDF tła"

#: .\pretix_furbadge\badge_renderer.py:102
msgid "Background PDF layout contains no readable pages."
msgstr "Układ pliku PDF tła nie zawiera czytelnych stron."

#: .\pretix_furbadge\badge_renderer.py:196
msgid "Attendee"
msgstr "Uczestnik"

#: .\pretix_furbadge\bot\commands.py:61
msgid "The shop is currently unavailable."
msgstr "Sklep jest obecnie niedostępny."

#: .\pretix_furbadge\bot\commands.py:71
msgid "Open shop"
msgstr "Otwórz sklep"

#: .\pretix_furbadge\bot\commands.py:77
msgid "No connected orders yet."
msgstr "Brak połączonych zamówień."

#: .\pretix_furbadge\bot\commands.py:87
#, python-brace-format
msgid ""
"Your orders:\n"
"{orders}\n"
"\n"
"Use /order <number> to open one."
msgstr ""
"Twoje zamówienia:\n"
"{orders}\n"
"\n"
"Użyj /order <numer>, aby otworzyć wybrane."

#: .\pretix_furbadge\bot\commands.py:99 .\pretix_furbadge\bot\commands.py:202
msgid "You have no connected orders yet."
msgstr "Nie masz jeszcze żadnych połączonych zamówień."

#: .\pretix_furbadge\bot\commands.py:106
msgid "Invalid order number. Use /orders to see the list."
msgstr "Nieprawidłowy numer zamówienia. Użyj /orders, aby zobaczyć listę."

#: .\pretix_furbadge\bot\commands.py:128
#, python-brace-format
msgid "Manage order {order_code}"
msgstr "Zarządzaj zamówieniem {order_code}"

#: .\pretix_furbadge\bot\commands.py:132 .\pretix_furbadge\bot\commands.py:215
msgid "Order could not be found."
msgstr "Nie znaleziono zamówienia."

#: .\pretix_furbadge\bot\commands.py:138
msgid "No badges yet."
msgstr "Brak badge'y."

#: .\pretix_furbadge\bot\commands.py:143
#, python-brace-format
msgid "order {order_code}"
msgstr "zamówienie {order_code}"

#: .\pretix_furbadge\bot\commands.py:147
#, python-brace-format
msgid ""
"Your badges:\n"
"{badges}\n"
"\n"
"Use /badge <number> to edit one."
msgstr ""
"Twoje badge'e:\n"
"{badges}\n"
"\n"
"Użyj /badge <numer>, aby edytować wybrany."

#: .\pretix_furbadge\bot\commands.py:159
msgid "You have no badges."
msgstr "Nie masz żadnych badge'y."

#: .\pretix_furbadge\bot\commands.py:166
msgid "Invalid badge number. Use /badges to see the list."
msgstr "Nieprawidłowy numer badge'a. Użyj /badges, aby zobaczyć listę."

#: .\pretix_furbadge\bot\commands.py:189
#, python-brace-format
msgid "Edit your badge for order {order_code}"
msgstr "Edytuj swój badge dla zamówienia {order_code}"

#: .\pretix_furbadge\bot\commands.py:208
msgid "Invalid number. Use /orders to see the list."
msgstr "Nieprawidłowy numer. Użyj /orders, aby zobaczyć listę."

#: .\pretix_furbadge\bot\commands.py:225
#, python-brace-format
msgid ""
"Tickets are not yet available for order {order_code} (status: {status})."
msgstr ""
"Bilety dla zamówienia {order_code} nie są jeszcze dostępne (status: "
"{status})."

#: .\pretix_furbadge\bot\commands.py:237
msgid "No ticket items found for this order."
msgstr "Nie znaleziono pozycji biletowych dla tego zamówienia."

#: .\pretix_furbadge\bot\commands.py:267
#, python-brace-format
msgid "Ticket QR Code — {order_code} ({item})"
msgstr "Kod QR biletu — {order_code} ({item})"

#: .\pretix_furbadge\bot\commands.py:277
#, python-brace-format
msgid ""
"An error occurred while generating the QR code photo for order {order_code}. "
"Please try again later."
msgstr ""
"Wystąpił błąd podczas generowania zdjęcia kodu QR dla zamówienia "
"{order_code}. Proszę spróbować ponownie później."

#: .\pretix_furbadge\bot\commands.py:285
msgid ""
"/shop — open the shop\n"
"/orders — list your orders\n"
"/order <n> — manage an order\n"
"/badges — list your badges\n"
"/badge <n> — edit a badge\n"
"/qr <n> — get the ticket/QR for an order"
msgstr ""
"/shop — otwórz sklep\n"
"/orders — lista Twoich zamówień\n"
"/order <n> — zarządzaj zamówieniem\n"
"/badges — lista Twoich badge'y\n"
"/badge <n> — edytuj badge\n"
"/qr <n> — pobierz bilet/QR dla zamówienia"

#: .\pretix_furbadge\exporter.py:38
msgid "Badge PDFs (ZIP)"
msgstr "Pliki PDF badge'y (ZIP)"

#: .\pretix_furbadge\exporter.py:49 .\pretix_furbadge\forms.py:198
#: .\pretix_furbadge\models.py:180
msgid "Badge Type"
msgstr "Typ badge'a"

#: .\pretix_furbadge\exporter.py:51
msgid "Leave empty to export all badge types."
msgstr "Pozostaw puste, aby wyeksportować wszystkie typy badge'y."

#: .\pretix_furbadge\exporter.py:57
msgid "Include preview overlay"
msgstr "Dołącz nakładkę podglądu"

#: .\pretix_furbadge\exporter.py:64
msgid "Output Format"
msgstr "Format wyjściowy"

#: .\pretix_furbadge\forms.py:50 .\pretix_furbadge\models.py:52
msgid "Background PDF"
msgstr "Plik PDF tła"

#: .\pretix_furbadge\forms.py:53 .\pretix_furbadge\models.py:53
msgid "The base layer for the badge."
msgstr "Warstwa bazowa badge'a."

#: .\pretix_furbadge\forms.py:56 .\pretix_furbadge\models.py:59
msgid "Foreground PDF"
msgstr "Plik PDF pierwszego planu"

#: .\pretix_furbadge\forms.py:59 .\pretix_furbadge\models.py:60
msgid "Overlay on top of the avatar and text."
msgstr "Nakładka wyświetlana na awatarze i tekście."

#: .\pretix_furbadge\forms.py:117 .\pretix_furbadge\models.py:31
msgid "Font File (TTF/OTF)"
msgstr "Plik czcionki (TTF/OTF)"

#: .\pretix_furbadge\forms.py:144
msgid "This doesn't look like a valid font file."
msgstr "To nie wygląda na prawidłowy plik czcionki."

#: .\pretix_furbadge\forms.py:168
msgid ""
"This font uses PostScript/CFF outlines and automatic conversion to TrueType "
"failed. Please convert it to .ttf manually before uploading."
msgstr ""
"Ta czcionka używa konturów PostScript/CFF, a automatyczna konwersja do "
"formatu TrueType nie powiodła się. Proszę przekonwertować ją ręcznie do "
"formatu .ttf przed przesłaniem."

#: .\pretix_furbadge\forms.py:195 .\pretix_furbadge\models.py:175
msgid "Product"
msgstr "Produkt"

#: .\pretix_furbadge\forms.py:223
msgid "Allow Badge Edits"
msgstr "Zezwalaj na edycję badge'a"

#: .\pretix_furbadge\forms.py:224
msgid "If enabled, attendees can edit their badge data."
msgstr "Jeśli włączone, uczestnicy mogą edytować dane swojego badge'a."

#: .\pretix_furbadge\forms.py:228
msgid "Badge Edit Deadline"
msgstr "Termin edycji badge'a"

#: .\pretix_furbadge\forms.py:233
msgid "Preview Overlay PDF"
msgstr "PDF nakładki podglądu"

#: .\pretix_furbadge\forms.py:234
msgid "Global overlay watermark applied only in previews."
msgstr "Globalny znak wodny nakładany wyłącznie na podglądy."

#: .\pretix_furbadge\forms.py:240
msgid "Question for Badge Nickname"
msgstr "Pytanie o nick na badge'u"

#: .\pretix_furbadge\forms.py:244
msgid ""
"Select the pretix question used to pull the attendee's badge nickname. If "
"not selected, the badge text will be an optional preference."
msgstr ""
"Wybierz pytanie z pretix, z którego pobierany będzie nick uczestnika na "
"badge. Jeśli nie zostanie wybrane, tekst na badge'u będzie opcjonalnym polem "
"preferencji."

#: .\pretix_furbadge\forms.py:250
msgid "Question for Public List Visibility"
msgstr "Pytanie o widoczność na liście publicznej"

#: .\pretix_furbadge\forms.py:254
msgid ""
"Select the pretix question used to decide whether the attendee should appear "
"in the public attendee list."
msgstr ""
"Wybierz pytanie z pretix, z którego pobierana będzie decyzja, czy uczestnik "
"ma się pojawić na publicznej liście uczestników."

#: .\pretix_furbadge\forms.py:259
msgid "Default Avatar"
msgstr "Domyślny awatar"

#: .\pretix_furbadge\forms.py:261
msgid ""
"Default avatar image used when no custom avatar is uploaded. If not set, no "
"avatar will be rendered."
msgstr ""
"Domyślny obraz awatara używany, gdy nie przesłano własnego awatara. Jeśli "
"nie zostanie ustawiony, awatar nie będzie renderowany."

#: .\pretix_furbadge\forms.py:324
msgid "Enable Telegram integration"
msgstr "Włącz integrację z Telegramem"

#: .\pretix_furbadge\forms.py:326
msgid "Allow attendees to connect their Telegram accounts to orders."
msgstr "Zezwól uczestnikom na łączenie kont Telegram ze swoimi zamówieniami."

#: .\pretix_furbadge\forms.py:330
msgid "Bot token from @BotFather"
msgstr "Token bota od @BotFather"

#: .\pretix_furbadge\forms.py:332
msgid "The bot token obtained from Telegram's BotFather."
msgstr "Token bota uzyskany za pomocą BotFather na Telegramie."

#: .\pretix_furbadge\forms.py:336
msgid "Bot username (without @)"
msgstr "Nazwa użytkownika bota (bez @)"

#: .\pretix_furbadge\forms.py:337
msgid "Used to build deep links in web_app buttons. Ex: 'YourEventBot'."
msgstr ""
"Służy do tworzenia głębokich linków (deep links) w przyciskach web_app. Np.: "
"'TwójEventBot'."

#: .\pretix_furbadge\forms.py:341
msgid "OIDC client ID"
msgstr "Identyfikator klienta OIDC"

#: .\pretix_furbadge\forms.py:344
msgid "Telegram's OpenID Connect client identifier for the Login Widget."
msgstr "Identyfikator klienta OpenID Connect Telegrama dla widżetu logowania."

#: .\pretix_furbadge\forms.py:349
msgid "OIDC client secret"
msgstr "Klucz tajny klienta OIDC"

#: .\pretix_furbadge\forms.py:351
msgid "Secret key for OIDC authentication with Telegram."
msgstr "Tajny klucz do uwierzytelniania OIDC za pomocą Telegrama."

#: .\pretix_furbadge\forms.py:355
msgid "Webhook secret token"
msgstr "Tajny token webhooka"

#: .\pretix_furbadge\forms.py:358
msgid "Pass this as secret_token when setting the webhook URL via BotFather."
msgstr ""
"Przekaż to jako secret_token podczas ustawiania adresu URL webhooka przez "
"BotFather."

#: .\pretix_furbadge\forms.py:363
msgid "Consent checkbox text"
msgstr "Tekst pola wyboru zgody"

#: .\pretix_furbadge\forms.py:365
msgid "Text displayed next to the consent checkbox on the order page."
msgstr "Tekst wyświetlany obok pola wyboru zgody na stronie zamówienia."

